{
  "name": "medhaclinic-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.vercel.json",
    "check": "npm run build && npm run typecheck",
    "postinstall": "prisma generate",
    "test": "node --import tsx --test",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "node ./scripts/run-prisma-with-env.mjs migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@prisma/client": "^6.6.0",
    "dotenv": "^16.4.7",
    "firebase-admin": "^13.4.0",
    "hono": "^4.7.7",
    "openai": "^6.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
