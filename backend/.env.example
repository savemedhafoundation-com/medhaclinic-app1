NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:8081,http://localhost:19006

# Hosted Postgres / Neon
# Use the pooled connection string for the Prisma client.
DATABASE_URL=postgresql://USER:PASSWORD@EP-XXXX-pooler.REGION.aws.neon.tech/medhaclinic?sslmode=require&pgbouncer=true&connect_timeout=15
# Use the direct connection string for Prisma migrations.
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@EP-XXXX.REGION.aws.neon.tech/medhaclinic?sslmode=require&connect_timeout=15

# Optional alternative for custom Postgres setups
# If you are not using a single DATABASE_URL, the backend can still build one
# from the values below.
DB_USER=medha_app
DB_PASS=
DB_NAME=medhaclinic
INSTANCE_CONNECTION_NAME=medhaclinic-3ba87:asia-south1:medha-db
DB_SOCKET_DIR=/cloudsql
DB_SCHEMA=public
DB_PORT=5432
# Optional direct TCP host for non-Cloud-Run production setups
DB_HOST=

# Firebase Admin
# Preferred: path to the downloaded service account JSON key
# GOOGLE_APPLICATION_CREDENTIALS=C:\\path\\to\\service-account.json
#
# Or copy values from the JSON file:
FIREBASE_PROJECT_ID=medhaclinic-3ba87
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@medhaclinic-3ba87.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional alternative to the three fields above
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"..."}

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Render + Neon reminder:
# NODE_ENV=production
# DATABASE_URL -> Neon pooled URL
# DIRECT_DATABASE_URL -> Neon direct URL
# FIREBASE_SERVICE_ACCOUNT_JSON -> Firebase Admin JSON secret
