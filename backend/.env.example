NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:8081,http://localhost:19006

# Local Prisma / Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medhaclinic?schema=public

# Cloud Run / Cloud SQL alternative
# In Cloud Run production, you can omit DATABASE_URL and let the backend build it
# from these values. Cloud Run mounts the Cloud SQL Unix socket at /cloudsql
# when you deploy with --add-cloudsql-instances.
DB_USER=medha_app
DB_PASS=
DB_NAME=medhaclinic
INSTANCE_CONNECTION_NAME=medhaclinic-3ba87:asia-south1:medha-db
DB_SOCKET_DIR=/cloudsql
DB_SCHEMA=public
DB_PORT=5432
# Optional direct TCP host for non-Cloud-Run production setups
DB_HOST=

# Firebase Admin
# Preferred: path to the downloaded service account JSON key
# GOOGLE_APPLICATION_CREDENTIALS=C:\\path\\to\\service-account.json
#
# In Cloud Run on the same Google Cloud / Firebase project, prefer Application
# Default Credentials from the attached service account instead of a JSON file.
#
# Or copy values from the JSON file:
FIREBASE_PROJECT_ID=medhaclinic-3ba87
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@medhaclinic-3ba87.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional alternative to the three fields above
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"..."}

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Cloud Run Variables & Secrets reminder:
# NODE_ENV=production
# DB_PASS should come from Secret Manager in Cloud Run, for example:
# DB_PASS -> Secret: DB_PASS:latest
