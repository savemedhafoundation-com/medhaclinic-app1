generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String                   @id @default(cuid())
  firebaseUid String                   @unique
  email       String?                  @unique
  name        String?
  photoUrl    String?
  provider    String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  profile     PatientProfile?
  submissions DailyImmunitySubmission[]
  reports     WeeklyReport[]
  aiSummaries AiSummary[]
}

model PatientProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  gender    String?
  age       Int?
  weightKg  Float?
  heightCm  Float?
  purpose   String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyImmunitySubmission {
  id                  String   @id @default(cuid())
  userId              String
  physicalEnergy      Int?
  appetite            Int?
  digestionComfort    Int?
  burningPain         Int?
  bloatingGas         Int?
  bloodPressure       Int?
  swelling            Int?
  fever               Int?
  infection           Int?
  breathingProblem    Int?
  menstrualRegularity Int?
  libidoStability     Int?
  hairHealth          Int?
  sleepHours          Int?
  immunityScore       Int
  immunityLevel       String
  submittedAt         DateTime @default(now())
  createdAt           DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiSummaries AiSummary[]

  @@index([userId, submittedAt])
}

model WeeklyReport {
  id              String   @id @default(cuid())
  userId          String
  weekStart       DateTime
  weekEnd         DateTime
  overallCurrent  Float
  overallPrevious Float?
  overallDelta    Float?
  trend           String
  payloadJson     Json
  generatedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekStart])
}

model AiSummary {
  id                 String   @id @default(cuid())
  userId             String
  sourceSubmissionId String?
  promptJson         Json
  resultText         String
  model              String
  createdAt          DateTime @default(now())

  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceSubmission DailyImmunitySubmission? @relation(fields: [sourceSubmissionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}
