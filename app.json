{
  "expo": {
    "name": "medhaclinic",
    "slug": "medha-clinic",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "medhaclinic",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A6800",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.medhaclinic.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "@react-native-google-signin/google-signin",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow MedhaClinic to access your photos so you can upload a profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "64bd29f2-7c0e-4a35-be76-0702cd8ffbef"
      },
      "publicConfig": {
        "backendUrl": "https://medha-backend-179498638620.asia-south1.run.app",
        "firebase": {
          "apiKey": "AIzaSyDZNg6cCLLKTGQb0Y5tPZXri0zwqK1aa6Q",
          "authDomain": "medhaclinic-3ba87.firebaseapp.com",
          "projectId": "medhaclinic-3ba87",
          "storageBucket": "medhaclinic-3ba87.firebasestorage.app",
          "messagingSenderId": "179498638620",
          "appId": "1:179498638620:android:d663a80b783b833028eed9"
        },
        "googleWebClientId": "179498638620-sv1b07lvisqh5i11j60goko7tgrls2v8.apps.googleusercontent.com"
      }
    },
    "owner": "hira2512"
  }
}
